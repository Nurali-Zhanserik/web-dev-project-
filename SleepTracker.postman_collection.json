    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/profile/"
          },
          "response": [{
            "name": "200 OK",
            "status": "OK",
            "code": 200,
            "body": "{\n  \"profile\": {\n    \"id\": 1,\n    \"username\": \"aman\",\n    \"email\": \"aman@example.com\",\n    \"bio\": \"\",\n    \"timezone\": \"UTC\",\n    \"created_at\": \"2024-04-01T00:00:00Z\",\n    \"updated_at\": \"2024-04-22T00:00:00Z\"\n  },\n  \"goal\": {\n    \"id\": 1,\n    \"target_duration_minutes\": 480,\n    \"target_duration_hours\": \"8h 0m\",\n    \"target_quality\": 4,\n    \"target_bedtime\": \"23:00:00\",\n    \"created_at\": \"2024-04-01T00:00:00Z\",\n    \"updated_at\": \"2024-04-22T00:00:00Z\"\n  },\n  \"user\": {\n    \"id\": 1,\n    \"username\": \"aman\",\n    \"email\": \"aman@example.com\"\n  }\n}"
