          }]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/categories/"
          },
          "response": [{
            "name": "200 OK",
            "status": "OK",
            "code": 200,
            "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"Work day\",\n    \"color\": \"#3b82f6\",\n    \"record_count\": 5,\n    \"created_at\": \"2024-04-01T00:00:00Z\"\n  }\n]"
          }]
